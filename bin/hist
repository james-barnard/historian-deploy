#!/usr/bin/env bash
# hist — Historian deployment CLI
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEPLOY_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOCK_FILE="$DEPLOY_ROOT/deployment.lock"
PAT_FILE="$DEPLOY_ROOT/.pat"
COMPOSE_FILE="$DEPLOY_ROOT/compose.registry.yml"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

lock_val() {
  grep -E "^${1}:" "$LOCK_FILE" 2>/dev/null | head -1 | sed "s/^${1}: *//" | tr -d "'"
}

lock_image_val() {
  local service="$1" field="$2"
  awk "/^  ${service}:/{found=1;next} /^  [^ ]/{found=0} found && /    ${field}:/{print \$2; exit}" "$LOCK_FILE" | tr -d "'"
}

detect_platform() {
  if [ -f /etc/nv_tegra_release ] || grep -qi "tegra\|jetson" /proc/device-tree/model 2>/dev/null; then
    echo "jetson"
  else
    echo "gx10"
  fi
}

# ---------------------------------------------------------------------------
# Deploy
# ---------------------------------------------------------------------------

cmd_deploy() {
  local version platform

  if [ ! -f "$LOCK_FILE" ]; then
    echo "❌ deployment.lock not found at $LOCK_FILE"
    exit 1
  fi

  version="$(lock_val version)"
  platform="$(detect_platform)"

  echo "🚀 Deploying Historian"
  echo "=================================================="
  echo "   Platform: $platform"
  echo "   Version:  $version"
  echo "   Commit:   $(lock_val git_commit)"
  echo ""

  # Auth
  if [ -f "$PAT_FILE" ]; then
    if [ -f ~/.docker/config.json ] && grep -q "ghcr.io" ~/.docker/config.json 2>/dev/null; then
      echo "🔑 GHCR: already authenticated"
    else
      echo "🔑 Authenticating with GHCR..."
      cat "$PAT_FILE" | docker login ghcr.io -u james-barnard --password-stdin 2>&1 | sed 's/^/   /'
    fi
  else
    echo "   ⚠️  No .pat file — pulls may fail for private images"
  fi
  echo ""

  # Pull images
  echo "📥 Pulling images..."
  local gx10_only="asr historian-tts"
  local jetson_only="asr-whisper"

  for service in $(grep -E '^  [a-z]' "$LOCK_FILE" | sed 's/:.*//' | tr -d ' '); do
    local image digest
    image="$(lock_image_val "$service" image)"
    digest="$(lock_image_val "$service" digest)"
    [ -z "$image" ] && continue

    # Skip external
    [ "$digest" = "external" ] && { printf "   %-18s external\n" "$service"; continue; }

    # Skip wrong-profile
    echo "$gx10_only" | grep -qw "$service" && [ "$platform" != "gx10" ] && { printf "   %-18s skip (%s-only)\n" "$service" "gx10"; continue; }
    echo "$jetson_only" | grep -qw "$service" && [ "$platform" != "jetson" ] && { printf "   %-18s skip (%s-only)\n" "$service" "jetson"; continue; }

    printf "   %-18s pulling..." "$service"
    if [ "$digest" != "unknown" ] && docker pull "${image%%:*}@${digest}" >/dev/null 2>&1; then
      docker tag "${image%%:*}@${digest}" "$image" 2>/dev/null
      echo " ✅"
    elif docker pull "$image" >/dev/null 2>&1; then
      echo " ✅"
    else
      echo " ⚠️"
    fi
  done
  echo ""

  # Clean slate + start
  echo "🧹 Cleaning up..."
  docker ps -a --filter name=historian- --format '{{.Names}}' | xargs -r docker rm -f 2>/dev/null || true
  REGISTRY_TAG="$version" docker compose -f "$COMPOSE_FILE" --profile "$platform" down --remove-orphans 2>/dev/null || true
  docker network prune -f >/dev/null 2>&1 || true

  echo "🚀 Starting services..."
  REGISTRY_TAG="$version" docker compose -f "$COMPOSE_FILE" --profile "$platform" up -d 2>&1 | sed 's/^/   /'

  # Migrations
  echo ""
  echo "🗄️  Running migrations..."
  local i=0
  while [ $i -lt 30 ]; do
    docker ps --format '{{.Names}}' | grep -q "^historian-app$" && break
    sleep 1; i=$((i + 1))
  done
  sleep 3

  if docker ps --format '{{.Names}}' | grep -q "^historian-app$"; then
    docker exec historian-app bundle exec ruby -e \
      "require_relative '/app/lib/db'; Db.connect!; require_relative '/app/lib/db_migrator'; DbMigrator.migrate!" 2>&1 | sed 's/^/   /' || true
  else
    echo "   ⚠️  app not running — will self-heal on restart"
  fi

  echo ""
  echo "✅ Deploy complete"
  cmd_status
}

# ---------------------------------------------------------------------------
# Status
# ---------------------------------------------------------------------------

cmd_status() {
  echo ""
  echo "📊 Services"
  echo "==========="
  docker ps --filter name=historian- --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

case "${1:-}" in
  deploy)  cmd_deploy ;;
  status)  cmd_status ;;
  *)
    echo "Usage: hist <deploy|status>"
    ;;
esac
