#!/usr/bin/env bash
# hist — Historian deployment CLI (pure shell, no Ruby required)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEPLOY_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOCK_FILE="$DEPLOY_ROOT/deployment.lock"
PAT_FILE="$DEPLOY_ROOT/.pat"
COMPOSE_FILE="$DEPLOY_ROOT/compose.registry.yml"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Read a value from deployment.lock (simple YAML — top-level or image fields)
lock_val() {
  grep -E "^${1}:" "$LOCK_FILE" 2>/dev/null | head -1 | sed "s/^${1}: *//" | tr -d "'"
}

lock_image_val() {
  local service="$1" field="$2"
  awk "/^  ${service}:/{found=1;next} /^  [^ ]/{found=0} found && /    ${field}:/{print \$2; exit}" "$LOCK_FILE" | tr -d "'"
}

# Detect platform (jetson vs gx10)
detect_platform() {
  if [ -f /etc/nv_tegra_release ] || grep -qi "tegra\|jetson" /proc/device-tree/model 2>/dev/null; then
    echo "jetson"
  else
    echo "gx10"
  fi
}

compose_cmd() {
  local platform
  platform="$(detect_platform)"
  echo "REGISTRY_TAG=$(lock_val version) docker compose -f $COMPOSE_FILE --profile $platform"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_deploy() {
  local version platform

  echo "🚀 Deploying Historian from deployment.lock"
  echo "=================================================="

  # Validate lock file
  if [ ! -f "$LOCK_FILE" ]; then
    echo "❌ deployment.lock not found at $LOCK_FILE"
    exit 1
  fi

  version="$(lock_val version)"
  platform="$(detect_platform)"
  echo "   Platform: $platform"
  echo "   Version:  $version"
  echo "   Commit:   $(lock_val git_commit)"
  echo ""

  # GHCR auth
  ghcr_auth

  # Pull images
  pull_images "$version" "$platform"

  # Clean slate + start
  start_services "$platform" "$version"

  # Run migrations (inside app container)
  run_migrations

  echo ""
  echo "✅ Deployment complete!"
  echo "🌐 Web: https://localhost:8443"
  echo ""
}

ghcr_auth() {
  # Already logged in?
  if [ -f ~/.docker/config.json ] && grep -q "ghcr.io" ~/.docker/config.json 2>/dev/null; then
    echo "🔑 GHCR: already authenticated"
    return
  fi

  if [ ! -f "$PAT_FILE" ]; then
    echo "   ⚠️  No .pat file — GHCR pulls may fail"
    return
  fi

  echo "🔑 Authenticating with GHCR..."
  cat "$PAT_FILE" | docker login ghcr.io -u james-barnard --password-stdin 2>&1 | sed 's/^/   /'
}

pull_images() {
  local version="$1" platform="$2"
  echo ""
  echo "📥 Pulling images..."
  echo ""

  # Services gated to specific profiles
  local gx10_only="asr historian-tts"
  local jetson_only="asr-whisper"

  # Read services from lock file
  for service in $(grep -E '^  [a-z]' "$LOCK_FILE" | sed 's/:.*//' | tr -d ' '); do
    local image digest

    image="$(lock_image_val "$service" image)"
    digest="$(lock_image_val "$service" digest)"

    [ -z "$image" ] && continue

    # Skip external
    if [ "$digest" = "external" ]; then
      printf "   📦 %-18s skipping (external)\n" "$service"
      continue
    fi

    # Skip wrong-profile services
    if echo "$gx10_only" | grep -qw "$service" && [ "$platform" != "gx10" ]; then
      printf "   📦 %-18s skipping (gx10-only)\n" "$service"
      continue
    fi
    if echo "$jetson_only" | grep -qw "$service" && [ "$platform" != "jetson" ]; then
      printf "   📦 %-18s skipping (jetson-only)\n" "$service"
      continue
    fi

    printf "   📦 %-18s pulling..." "$service"

    # Try digest first, fall back to tag
    if [ "$digest" != "unknown" ]; then
      local repo="${image%%:*}"
      if docker pull "${repo}@${digest}" >/dev/null 2>&1; then
        docker tag "${repo}@${digest}" "$image" 2>/dev/null
        echo " ✅"
        continue
      fi
    fi

    # Fall back to tag
    if docker pull "$image" >/dev/null 2>&1; then
      echo " ✅"
    else
      echo " ⚠️ failed"
    fi
  done
  echo ""
}

start_services() {
  local platform="$1" version="$2"
  echo "🚀 Starting services..."
  echo ""

  # Clean slate: kill all historian containers
  echo "   🧹 Stopping existing containers..."
  docker ps -a --filter name=historian- --format '{{.Names}}' | xargs -r docker rm -f 2>/dev/null || true
  REGISTRY_TAG="$version" docker compose -f "$COMPOSE_FILE" --profile "$platform" down --remove-orphans 2>&1 | sed 's/^/   /' || true
  docker network prune -f >/dev/null 2>&1 || true

  # Bring up
  echo "   🚀 Starting..."
  if REGISTRY_TAG="$version" docker compose -f "$COMPOSE_FILE" --profile "$platform" up -d 2>&1 | sed 's/^/   /'; then
    echo "   ✅ Services started"
  else
    echo "   ❌ Failed to start services"
    exit 1
  fi
  echo ""
}

run_migrations() {
  echo "🗄️  Running database migrations..."

  # Wait for app container (up to 30s)
  local i=0
  while [ $i -lt 30 ]; do
    if docker ps --format '{{.Names}}' | grep -q "^historian-app$"; then
      break
    fi
    sleep 1
    i=$((i + 1))
  done

  if ! docker ps --format '{{.Names}}' | grep -q "^historian-app$"; then
    echo "   ⚠️  historian-app not running — skipping migrations"
    return
  fi

  # Wait a moment for the container to initialize
  sleep 3

  if docker exec historian-app bundle exec ruby -e \
    "require_relative '/app/lib/db'; Db.connect!; require_relative '/app/lib/db_migrator'; DbMigrator.migrate!" 2>&1 | sed 's/^/   /'; then
    echo "   ✅ Migrations complete"
  else
    echo "   ⚠️  Migration failed (app will self-heal on restart)"
  fi
}

cmd_status() {
  echo "📊 Historian Service Status"
  echo "==========================="
  docker ps --filter name=historian- --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null
}

cmd_logs() {
  local service="${1:-}"
  if [ -z "$service" ]; then
    echo "Usage: hist logs <service>"
    echo "Services: app, sidekiq, audio-gateway, asr-whisper, embed, ollama, redis, chroma-db, app-proxy"
    exit 1
  fi
  docker logs --tail 100 -f "historian-${service}" 2>&1
}

cmd_restart() {
  local service="${1:-}"
  if [ -z "$service" ]; then
    echo "Restarting all historian services..."
    docker ps --filter name=historian- --format '{{.Names}}' | xargs -r docker restart
  else
    echo "Restarting historian-${service}..."
    docker restart "historian-${service}"
  fi
}

cmd_stop() {
  echo "Stopping all historian services..."
  docker ps --filter name=historian- --format '{{.Names}}' | xargs -r docker stop
}

cmd_help() {
  cat <<EOF
hist — Historian deployment CLI

Usage: hist <command> [args]

Commands:
  deploy              Deploy from deployment.lock
  status              Show service status
  logs <service>      Follow service logs
  restart [service]   Restart service(s)
  stop                Stop all services
  help                Show this help

Examples:
  hist deploy
  hist status
  hist logs app
  hist restart audio-gateway
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

case "${1:-help}" in
  deploy)   cmd_deploy ;;
  status)   cmd_status ;;
  logs)     cmd_logs "${2:-}" ;;
  restart)  cmd_restart "${2:-}" ;;
  stop)     cmd_stop ;;
  help|-h)  cmd_help ;;
  *)        echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
