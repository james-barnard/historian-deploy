# Historian Environment Configuration for Jetson Platform
# Copy this file to prod.env or .env and customize the values

# Storage Configuration
HIST_VAULT_DIR=/var/lib/historian/vault
HIST_DB_PATH=/var/lib/historian/db/historian.sqlite
HIST_MODELS_DIR=/var/lib/historian/models
HIST_LOGS_DIR=/var/log/historian

# External Service URLs (uncomment and configure if running locally)
# HIST_ASR_URL=http://localhost:9000
# HIST_EMBED_URL=http://localhost:8000

# Redis Configuration
REDIS_URL=redis://localhost:6379

# TTS Configuration (historian-tts output gain)
# TTS_VOLUME=1.5   # e.g. 1.5 = 50% louder, 2.0 = 2x (may clip)

# Application Configuration
RACK_ENV=production
HIST_APP_PORT=8443

# Logging Configuration
HIST_LOG_LEVEL=info
HIST_LOG_MAX_SIZE=100m
HIST_LOG_MAX_FILES=3

# Performance Configuration
HIST_WORKER_THREADS=4
HIST_MAX_CONNECTIONS=100
HIST_REQUEST_TIMEOUT=30

# Security Configuration
HIST_ENABLE_HTTPS=false
HIST_SSL_CERT_PATH=
HIST_SSL_KEY_PATH=

# Backup Configuration
HIST_BACKUP_ENABLED=true
HIST_BACKUP_RETENTION_DAYS=30
HIST_BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# Monitoring Configuration
HIST_MONITORING_ENABLED=true
HIST_HEALTH_CHECK_INTERVAL=300  # 5 minutes
HIST_METRICS_ENABLED=true

# Memory Consolidation Configuration
HIST_MEMORY_CONSOLIDATION_INTERVAL=3600  # 1 hour
HIST_QUESTION_GENERATION_ENABLED=true
HIST_MAX_QUESTIONS_PER_RUN=100

# Development/Debug Configuration (set to false in production)
HIST_DEBUG_ENABLED=false
HIST_VERBOSE_LOGGING=false
# HIST_E2EE_DEBUG=0  # Set to 1 to enable verbose E2EE crypto logs (decryption, key derivation)
